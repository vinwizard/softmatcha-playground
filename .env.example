BACKEND_MODE=mock
HOST=127.0.0.1
PORT=8000
LOG_DIR=./logs
LOG_LEVEL=INFO
LOG_MAX_BYTES=5242880
LOG_BACKUP_COUNT=5

CORPUS_STORAGE_DIR=./data/corpora

SOFTMATCHA_PROJECT_DIR=~/softmatcha2
SOFTMATCHA_INDEX_DIR=corpus_index
SOFTMATCHA_INDEX_BUILD_CMD=uv run softmatcha-index
SOFTMATCHA_SEARCH_CMD=uv run softmatcha-search
SOFTMATCHA_EXACT_CMD=uv run softmatcha-exact
SOFTMATCHA_INDEX_FLAG=--index
SOFTMATCHA_SEARCH_MIN_SIMILARITY=0.4
SOFTMATCHA_COMMAND_TIMEOUT=30

MOCK_RESULT_COUNT=5
